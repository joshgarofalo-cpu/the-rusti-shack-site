# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase — product catalog
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx   # publishable/anon key (browser-safe, RLS-protected)

# Stripe (test mode) — added later
# STRIPE_SECRET_KEY=sk_test_xxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Supabase service role — SECRET, server-side only, NEVER commit. Needed to write
# the customer/order tables (they're RLS-locked). Add to .env.local and Vercel.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
